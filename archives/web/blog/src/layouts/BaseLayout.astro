---
import "../styles/global.css";

const { title = "Astro Blog", description = "Astro markdown blog" } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">MyCase Blog</a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/search">Search</a>
        <a href="/tags">Topics</a>
        <a href="/categories">Categories</a>
        <a href="/write">Write</a>
        <a href="/sponsor" class="site-nav__cta">Sponsor</a>
      </nav>
    </header>
    <div class="site-sponsor-strip">
      <p>이번 주말 배포 슬롯을 열어 두었습니다.</p>
      <a href="/sponsor">이 페이지 스폰서 하기</a>
    </div>
    <main class="shell">
      <slot />
    </main>
  </body>
</html>
