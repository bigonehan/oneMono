---
import "../styles/global.css";

const { title = "개인 블로그", description = "개인이 글을 작성하고 발행하는 티스토리형 블로그" } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div>
        <a href="/" class="brand">blog-personal</a>
        <p class="brand-copy">기록과 생각을 차분하게 쌓는 개인 블로그</p>
      </div>
      <nav class="site-nav">
        <a href="/">홈</a>
        <a href="/search">검색</a>
        <a href="/tags">태그</a>
        <a href="/categories">카테고리</a>
        <a href="/write" class="site-nav__cta">글쓰기</a>
      </nav>
    </header>
    <div class="site-notice">
      <p>오늘의 메모</p>
      <strong>작은 초안이라도 공개 가능한 글까지 밀어붙이는 연습을 합니다.</strong>
    </div>
    <main class="shell">
      <slot />
    </main>
  </body>
</html>
