---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

const { id } = Astro.params;
let course: {
  id: string;
  title: string;
  detail: string;
  lectures: Array<{ id: string; title: string; durationSec: number }>;
  reviews: Array<{ id: string; rating: number; content: string }>;
} | null = null;
let error = '';

try {
  const data = await queryGraphQL<{ detailCourse: typeof course }>(`
    query DetailPage($id: ID!) {
      detailCourse(id: $id) {
        id title detail
        lectures { id title durationSec }
        reviews { id rating content }
      }
    }
  `, { id });
  course = data.detailCourse;
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Detail | Lecture">
  <h1>강의 상세</h1>
  {error ? <p class="card">API 오류: {error}</p> : course ? (
    <section class="grid">
      <article class="card">
        <h2>{course.title}</h2>
        <p>{course.detail}</p>
      </article>
      <article class="card">
        <h3>커리큘럼</h3>
        <ul>
          {course.lectures.map((lecture) => <li>{lecture.title} ({Math.floor(lecture.durationSec / 60)}분)</li>)}
        </ul>
      </article>
      <article class="card">
        <h3>리뷰</h3>
        <ul>
          {course.reviews.map((review) => <li>{'★'.repeat(review.rating)} - {review.content}</li>)}
        </ul>
      </article>
    </section>
  ) : <p class="card">강의를 찾을 수 없습니다.</p>}
</BaseLayout>
