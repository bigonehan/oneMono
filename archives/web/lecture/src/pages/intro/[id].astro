---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

const { id } = Astro.params;
let course: { id: string; title: string; intro: string; category: string; price: number } | null = null;
let error = '';

try {
  const data = await queryGraphQL<{ introCourse: { id: string; title: string; intro: string; category: string; price: number } | null }>(`
    query IntroPage($id: ID!) {
      introCourse(id: $id) { id title intro category price }
    }
  `, { id });
  course = data.introCourse;
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Intro | Lecture">
  <h1>강의 소개</h1>
  {error ? <p class="card">API 오류: {error}</p> : course ? (
    <article class="card">
      <h2>{course.title}</h2>
      <p>{course.intro}</p>
      <p>{course.category} · {course.price.toLocaleString()}원</p>
      <a href={`/detail/${course.id}`}>상세 보기</a>
    </article>
  ) : <p class="card">강의를 찾을 수 없습니다.</p>}
</BaseLayout>
