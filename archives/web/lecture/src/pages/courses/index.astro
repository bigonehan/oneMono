---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

let courses = [] as Array<{ id: string; title: string; intro: string; category: string; price: number }>;
let error = '';

try {
  const data = await queryGraphQL<{ mainCourses: { edges: Array<{ node: { id: string; title: string; intro: string; category: string; price: number } }> } }>(`
    query CoursesPage {
      mainCourses(first: 50) {
        edges { node { id title intro category price } }
      }
    }
  `);
  courses = data.mainCourses.edges.map((edge) => edge.node);
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Courses | Lecture">
  <h1>전체 강의 목록</h1>
  {error ? <p class="card">API 오류: {error}</p> : (
    <section class="grid two">
      {courses.map((course) => (
        <article class="card">
          <h2>{course.title}</h2>
          <p>{course.intro}</p>
          <p class="muted">{course.category} · {course.price.toLocaleString()}원</p>
          <p><a href={`/courses/${course.id}`}>상세</a> · <a href={`/courses/${course.id}/learn`}>수강하기</a></p>
        </article>
      ))}
    </section>
  )}
</BaseLayout>
