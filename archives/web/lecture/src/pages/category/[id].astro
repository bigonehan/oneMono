---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

const id = (Astro.params.id ?? '').toLowerCase();
let courses = [] as Array<{ id: string; title: string; intro: string; category: string; price: number }>;
let error = '';

try {
  const data = await queryGraphQL<{ mainCourses: { edges: Array<{ node: { id: string; title: string; intro: string; category: string; price: number } }> } }>(`
    query CategoryPage {
      mainCourses(first: 50) { edges { node { id title intro category price } } }
    }
  `);
  courses = data.mainCourses.edges.map((edge) => edge.node).filter((course) => course.category.toLowerCase().includes(id));
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Category | Lecture">
  <h1>카테고리: {Astro.params.id}</h1>
  {error ? <p class="card">API 오류: {error}</p> : (
    <section class="grid two">
      {courses.map((course) => (
        <article class="card">
          <h2>{course.title}</h2>
          <p>{course.intro}</p>
          <p><a href={`/courses/${course.id}`}>상세 보기</a></p>
        </article>
      ))}
      {courses.length === 0 ? <p class="card">해당 카테고리 강의가 없습니다.</p> : null}
    </section>
  )}
</BaseLayout>
