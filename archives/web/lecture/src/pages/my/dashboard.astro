---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

let page: {
  user: { name: string };
  enrollments: Array<{ id: string; courseId: string; status: string }>;
  progresses: Array<{ id: string; percent: number }>;
} | null = null;
let error = '';

try {
  const data = await queryGraphQL<{ userPage: typeof page }>(`
    query DashboardPage {
      userPage(userId: "u1") {
        user { name }
        enrollments { id courseId status }
        progresses { id percent }
      }
    }
  `);
  page = data.userPage;
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Dashboard | Lecture">
  <h1>내 학습 현황</h1>
  {error ? <p class="card">API 오류: {error}</p> : page ? (
    <section class="grid two">
      <article class="card">
        <h2>{page.user.name}</h2>
        <p>수강 중인 강의 {page.enrollments.length}개</p>
      </article>
      <article class="card">
        <h3>진도</h3>
        <ul>{page.progresses.map((p) => <li>{p.percent}%</li>)}</ul>
      </article>
    </section>
  ) : <p class="card">데이터가 없습니다.</p>}
</BaseLayout>
