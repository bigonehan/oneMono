---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts, getPostBySlug, getSeriesPosts } from "../../lib/posts";

export const getStaticPaths = async () =>
  getAllPosts().map((post) => ({
    params: { name: post.slug },
  }));

const name = Astro.params.name ?? "";
const postResult = getPostBySlug(name);
if (!postResult) {
  throw new Error(`post not found: ${name}`);
}

const { post, prev, next } = postResult;
const seriesPosts = post.series ? getSeriesPosts(post.series) : [];
---

<BaseLayout title={post.title} description={post.description}>
  <article class="article">
    <h1>{post.title}</h1>
    <p class="meta">{post.date} · {post.category}</p>
    <div class="tags">
      {post.tags.map((tag) => (
        <a href={`/tags/${tag}`}>#{tag}</a>
      ))}
    </div>
    <pre>{post.content}</pre>
  </article>

  {seriesPosts.length > 0 && (
    <section>
      <h2>Series: {post.series}</h2>
      <ol>
        {seriesPosts.map((item) => (
          <li>
            <a href={`/article/${item.slug}`} class={item.slug === post.slug ? "active" : ""}>
              {item.seriesOrder}. {item.title}
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

  <nav class="pager">
    {prev && <a href={`/article/${prev.slug}`}>← {prev.title}</a>}
    {next && <a href={`/article/${next.slug}`}>{next.title} →</a>}
  </nav>
</BaseLayout>
