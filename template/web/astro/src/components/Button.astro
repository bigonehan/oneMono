---
const { class: className, ...props } = Astro.props;
---

<button
  class:list={[
    "focus:ring-opacity-75 appearance-none rounded-lg bg-purple-500 px-4 py-2 font-semibold text-white shadow-md hover:bg-purple-700 focus:ring-2 focus:ring-purple-400 focus:outline-none",
    className,
  ]}
  {...props}
>
  <slot />
</button>

<script>
  import confetti from "canvas-confetti";

  const button = document.currentScript.previousElementSibling;

  if (button) {
    button.addEventListener("click", () => confetti());
  }
</script>
