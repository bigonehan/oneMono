{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-astro-template",
  "version": "0.1.0",
  "identifier": "com.home.template.desktop.astro",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:4421"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Astro Template",
        "width": 1120,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
