---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search">
  <h1>Search</h1>
  <input id="search-input" placeholder="검색어를 입력하세요" />
  <p id="search-guide">검색어 2자 이상 입력 시 검색이 실행됩니다.</p>
  <ul id="search-results"></ul>

  <script>
    import Fuse from "fuse.js";

    const input = document.querySelector<HTMLInputElement>("#search-input");
    const guide = document.querySelector<HTMLParagraphElement>("#search-guide");
    const results = document.querySelector<HTMLUListElement>("#search-results");

    let index: Array<{ slug: string; title: string; description: string; tags: string[]; content: string }> = [];
    let fuse: Fuse<{ slug: string; title: string; description: string; tags: string[]; content: string }> | null = null;

    const ensureIndex = async () => {
      if (fuse) return;
      const response = await fetch("/search-index.json");
      index = (await response.json()) as typeof index;
      fuse = new Fuse(index, {
        includeScore: true,
        threshold: 0.35,
        keys: [
          { name: "title", weight: 0.4 },
          { name: "description", weight: 0.2 },
          { name: "tags", weight: 0.25 },
          { name: "content", weight: 0.15 },
        ],
      });
    };

    const render = (rows: Array<{ slug: string; title: string; description: string }>) => {
      if (!results) return;
      results.innerHTML = rows
        .map((row) => `<li><a href="/posts/${row.slug}">${row.title}</a><p>${row.description}</p></li>`)
        .join("");
    };

    if (input && guide && results) {
      input.addEventListener("input", async () => {
        const query = input.value.trim();
        if (query.length < 2) {
          guide.textContent = "검색어 2자 이상 입력 시 검색이 실행됩니다.";
          render([]);
          return;
        }

        await ensureIndex();
        const matched = fuse?.search(query) ?? [];
        if (matched.length === 0) {
          guide.textContent = "검색 결과가 없습니다.";
          render([]);
          return;
        }

        guide.textContent = `${matched.length}개의 결과`;
        render(matched.map((item) => item.item));
      });
    }
  </script>
</BaseLayout>
