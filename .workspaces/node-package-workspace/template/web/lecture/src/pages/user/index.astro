---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../lib/api';

let page: {
  user: { id: string; name: string; email: string; role: string };
  enrollments: Array<{ id: string; courseId: string; status: string }>;
  progresses: Array<{ id: string; percent: number }>;
  certifications: Array<{ id: string; verifyUrl: string }>;
  notifications: Array<{ id: string; message: string }>;
} | null = null;
let error = '';
const fallbackPage = {
  user: { id: 'u1', name: 'Lee Student', email: 'student@lecture.dev', role: 'student' },
  enrollments: [{ id: 'e-fallback', courseId: 'temp-study', status: 'active' }],
  progresses: [{ id: 'p-fallback', percent: 0 }],
  certifications: [],
  notifications: [{ id: 'n-fallback', message: '백엔드 연결 대기 중입니다.' }]
};

try {
  const data = await queryGraphQL<{ userPage: typeof page }>(`
    query UserPage {
      userPage(userId: "u1") {
        user { id name email role }
        enrollments { id courseId status }
        progresses { id percent }
        certifications { id verifyUrl }
        notifications { id message }
      }
    }
  `);
  page = data.userPage;
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
  page = fallbackPage;
}
---
<BaseLayout title="User | Lecture">
  <h1>사용자 페이지</h1>
  {error ? <p class="card">API 연결 실패로 임시 데이터로 표시 중: {error}</p> : null}
  {page ? (
    <section class="grid">
      <article class="card">
        <h2>{page.user.name}</h2>
        <p>{page.user.email} · {page.user.role}</p>
      </article>
      <article class="card">
        <h3>수강</h3>
        <ul>{page.enrollments.map((item) => <li>{item.courseId} - {item.status}</li>)}</ul>
      </article>
      <article class="card">
        <h3>진도</h3>
        <ul>{page.progresses.map((item) => <li>{item.percent}%</li>)}</ul>
      </article>
      <article class="card">
        <h3>수료증/알림</h3>
        <ul>{page.certifications.map((item) => <li>{item.id} - {item.verifyUrl}</li>)}</ul>
        <ul>{page.notifications.map((item) => <li>{item.message}</li>)}</ul>
      </article>
    </section>
  ) : <p class="card">사용자 정보를 찾을 수 없습니다.</p>}
</BaseLayout>
