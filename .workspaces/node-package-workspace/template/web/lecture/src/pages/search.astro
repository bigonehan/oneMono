---
import BaseLayout from '../layouts/BaseLayout.astro';
import { queryGraphQL } from '../lib/api';

const keyword = (Astro.url.searchParams.get('keyword') ?? '').toLowerCase();
const category = (Astro.url.searchParams.get('category') ?? '').toLowerCase();
let courses = [] as Array<{ id: string; title: string; intro: string; category: string; price: number }>;
let error = '';

try {
  const data = await queryGraphQL<{ mainCourses: { edges: Array<{ node: { id: string; title: string; intro: string; category: string; price: number } }> } }>(`
    query SearchPage {
      mainCourses(first: 50) { edges { node { id title intro category price } } }
    }
  `);
  courses = data.mainCourses.edges.map((edge) => edge.node).filter((course) => {
    const keywordMatch = keyword ? `${course.title} ${course.intro}`.toLowerCase().includes(keyword) : true;
    const categoryMatch = category ? course.category.toLowerCase().includes(category) : true;
    return keywordMatch && categoryMatch;
  });
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Search | Lecture">
  <h1>강의 검색</h1>
  <form class="card" method="get">
    <div class="controls">
      <input name="keyword" value={Astro.url.searchParams.get('keyword') ?? ''} placeholder="키워드" />
      <input name="category" value={Astro.url.searchParams.get('category') ?? ''} placeholder="카테고리" />
      <button type="submit">검색</button>
    </div>
  </form>
  {error ? <p class="card">API 오류: {error}</p> : (
    <section class="grid two">
      {courses.map((course) => (
        <article class="card">
          <h2>{course.title}</h2>
          <p>{course.intro}</p>
          <p class="muted">{course.category} · {course.price.toLocaleString()}원</p>
          <p><a href={`/courses/${course.id}`}>강의 보기</a></p>
        </article>
      ))}
      {courses.length === 0 ? <p class="card">검색 결과가 없습니다.</p> : null}
    </section>
  )}
</BaseLayout>
