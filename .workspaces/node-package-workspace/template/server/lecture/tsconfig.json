{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@domains/user": ["src/domains/user/user.domain"],
      "@domains/review": ["src/domains/review/review.domain"],
      "@domains/study/*": ["src/domains/study/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
