---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { queryGraphQL } from '../../../lib/api';

const { id } = Astro.params;
let course: { id: string; title: string; lectures: Array<{ id: string; title: string; durationSec: number }> } | null = null;
let error = '';

try {
  const data = await queryGraphQL<{ detailCourse: { id: string; title: string; lectures: Array<{ id: string; title: string; durationSec: number }> } | null }>(`
    query LearnPage($id: ID!) {
      detailCourse(id: $id) {
        id title
        lectures { id title durationSec }
      }
    }
  `, { id });
  course = data.detailCourse;
} catch (err) {
  error = err instanceof Error ? err.message : 'unknown error';
}
---
<BaseLayout title="Learn | Lecture">
  <h1>강의 플레이어</h1>
  {error ? <p class="card">API 오류: {error}</p> : course ? (
    <section class="grid">
      <article class="card">
        <h2>{course.title}</h2>
        <p class="muted">학습 진도는 30초마다 임시 저장 시뮬레이션을 수행합니다.</p>
        <div class="controls">
          <button id="start">재생 시작</button>
          <span id="progressText">진도: 0%</span>
        </div>
        <progress id="progressBar" value="0" max="100"></progress>
      </article>
      <article class="card">
        <h3>강의 목록</h3>
        <ul>{course.lectures.map((lecture) => <li>{lecture.title}</li>)}</ul>
      </article>
    </section>
  ) : <p class="card">수강 정보를 찾을 수 없습니다.</p>}
  <script>
    const start = document.getElementById('start');
    const text = document.getElementById('progressText');
    const bar = document.getElementById('progressBar');
    if (start instanceof HTMLButtonElement && text && bar instanceof HTMLProgressElement) {
      let current = 0;
      start.addEventListener('click', () => {
        const timer = setInterval(() => {
          current = Math.min(current + 10, 100);
          bar.value = current;
          text.textContent = `진도: ${current}%`;
          localStorage.setItem(`progress:${location.pathname}`, String(current));
          if (current >= 100) {
            clearInterval(timer);
          }
        }, 300);
      }, { once: true });
    }
  </script>
</BaseLayout>
