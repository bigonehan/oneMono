---
import BaseLayout from "../layouts/BaseLayout.astro";
import { WriteArticleForm } from "../components/WriteArticleForm";
---

<BaseLayout title="Write">
  <section class="write-page">
    <div class="write-page__intro">
      <p class="eyebrow">WRITE POST</p>
      <h1>새 글 작성</h1>
      <p>제목, 날짜, 태그, 카테고리와 본문을 입력하면 `posts/` 아래에 새 글이 저장됩니다.</p>
    </div>
    <WriteArticleForm client:load />
  </section>
</BaseLayout>
